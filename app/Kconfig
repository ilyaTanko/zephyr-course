menuconfig LED_SUBSYSTEM
    bool "LED subsystem"
    default y
    help
      "Enable the LED subsystem"

if LED_SUBSYSTEM

choice
    prompt "Select the LED blink speed"
    default BLINK_SLEEP_1000_MS

config BLINK_SLEEP_250_MS
    bool "Rapid"

config BLINK_SLEEP_500_MS
    bool "Fast"

config BLINK_SLEEP_1000_MS
    bool "Normal"

config BLINK_SLEEP_2000_MS
    bool "Slow"

endchoice

config BLINK_SLEEP_TIME_MS
    int
    default 250 if BLINK_SLEEP_250_MS
    default 500 if BLINK_SLEEP_500_MS
    default 1000 if BLINK_SLEEP_1000_MS
    default 2000 if BLINK_SLEEP_2000_MS
    default 0
    help
      "The time in milliseconds that the LED will be on and off when blinking."

menuconfig LED_ADVANCED_SETTINGS
    bool "Advanced LED settings"
    default n
    help
      "Enable advanced LED settings"


if LED_ADVANCED_SETTINGS

config LED_BRIGHTNESS
    int "LED brightness"
    default 100
    range 0 100
    help
      "The brightness level of the LED (0-100%)"

config LED_FADE_DURATION_MS
    int "LED fade duration"
    default 500
    range 0 5000
    help
      "The duration in milliseconds for the LED to fade in and out."

menu "Expert settings"
    visible if LED_ADVANCED_SETTINGS

config LED_DEBUGGING
    bool "Enable LED debugging"
    default n
    help
      "Enable additional debug output for LED operations."

config LED_CUSTOM_PATTERN
    bool "Use custom LED pattern"
    default n
    help
      "Enable a custom LED blinking pattern instead of the default on/off pattern."

endmenu

endif # LED_ADVANCED_SETTINGS

endif # LED_SUBSYSTEM


config APP_HEARTBEAT_PERIOD_MS
    int "Heartbeat period (ms)"
    default 500
    range 100 2000
    help
      "The period in milliseconds for the heartbeat LED to toggle."

source "Kconfig.zephyr"